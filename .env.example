PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

JWT_SECRET=change-me
JWT_EXPIRES_IN=900s

# Solo para desarrollo: pnpm run seed:user
SEED_EMAIL=
SEED_PASSWORD=
SEED_NAME=Admin

# Resend (SMTP: smtp.resend.com). MAIL_FROM debe ser dominio verificado en Resend;
# NO uses @gmail.com ni el email del usuario aquí (ese va en replyTo automáticamente).
# Con onboarding@resend.dev solo llegan correos al email de tu cuenta Resend; para clientes reales,
# verifica tu dominio en https://resend.com/domains y usa MAIL_FROM=cotizaciones@tudominio.com
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME=Cotizador
MAIL_ENABLED=true
